  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 512546555}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b6043d64dac548b2a31d1c39c9daf0da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  CurrentString: 
  script:
  - Hey {{User}}
  - Op de dag van je scan
  - moet je naar het ziekenhuis toe.
  - Daar ben je nu helemaal klaar voor, topper.
  - Als je in het ziekenhuis bent,
  - melden je ouders je aan
  - om te zeggen dat je er bent.
  - Als je dan even gewacht hebt in de wachtkamer
  - komt de dokter je halen
  - en is het tijd voor de echte scan.
  - SUCCES!
  - Je kan het!
  ScriptIndex: 0
